{
  "title": "Buttermilk Pancakes",
  "servings": 4,
  "ingredients": [
    "2 cups all-purpose flour",
    "2 tbsp sugar",
    "2 tsp baking powder",
    "1/2 tsp salt",
    "2 cups buttermilk",
    "2 eggs",
    "1/4 cup butter, melted"
  ],
  "steps": [
    "Whisk dry ingredients.",
    "Mix wet ingredients and combine.",
    "Cook on a griddle until golden."
  ],
  "tags": ["breakfast"]
}
